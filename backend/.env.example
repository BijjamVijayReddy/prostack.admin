PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/prostack
JWT_SECRET=your_strong_secret_key_here
# Token lifetime — use e.g. 2h for production, 3m for testing
JWT_EXPIRES_IN=2h
NODE_ENV=development

# ── MSG91 MFA / Email OTP ──────────────────────────────────
# Get your Auth Key from https://control.msg91.com/signin
MSG91_AUTH_KEY=your_msg91_auth_key_here
# Verified sender address in your MSG91 account
MSG91_FROM_EMAIL=noreply@yourdomain.com
# Verified sending domain in your MSG91 account
MSG91_DOMAIN=yourdomain.com